      },
      "devices": {
        "title": "Paired Devices",
        "description": "Enter the 6-digit hex codes of your paired DuoFern devices, separated by commas.",
        "data": {
          "paired_devices": "Device Codes"
        },
        "data_description": {
          "paired_devices": "Comma-separated list of 6-digit hex device codes (e.g. 406B0D, 4090EA, 40B689). These are the codes of your DuoFern devices."
        }
      },
      "confirm_discovery": {
        "title": "Add DuoFern device",
        "description": "Do you want to add **{name}** to the integration?"
      }
    },
    "error": {
      "cannot_connect": "Failed to connect to the DuoFern stick. Check the serial port path.",
