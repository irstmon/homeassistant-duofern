  "config": {
    "step": {
      "user": {
        "title": "Rademacher DuoFern USB Stick",
        "description": "Configure the connection to your DuoFern USB stick.",
        "data": {
          "serial_port": "Serial Port",
          "system_code": "System Code (6-digit hex, starts with 6F)"
